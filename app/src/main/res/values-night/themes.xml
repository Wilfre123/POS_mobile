<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Dark Mode. -->
    <style name="Theme.BluePOS" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/accent_green</item>

        <!-- Force light background and dark text even in Dark Mode -->
        <item name="android:windowBackground">@color/light_green_bg</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_text</item>
        <item name="android:editTextColor">@color/black</item>
        <item name="android:textColorHint">@color/gray_text</item>

        <item name="drawerArrowStyle">@style/WhiteDrawerArrowStyle</item>
    </style>
</resources>